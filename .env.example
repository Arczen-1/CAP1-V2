# ============================================
# JUAN CARLOS EVENT MANAGEMENT - ENV CONFIG
# ============================================

# -------------------------------------------------
# STEP 1: MongoDB Connection (REQUIRED)
# -------------------------------------------------
# Option A: MongoDB Atlas (Cloud - Recommended)
# 1. Go to https://www.mongodb.com/cloud/atlas
# 2. Create a free account
# 3. Create a cluster (free tier is fine)
# 4. Click "Database Access" → "Add New Database User"
# 5. Create a username and password (SAVE THESE!)
# 6. Click "Network Access" → "Add IP Address" → "Allow Access from Anywhere" (0.0.0.0/0)
# 7. Click "Clusters" → "Connect" → "Drivers" → "Node.js"
# 8. Copy the connection string and paste below
#    Replace <password> with your actual password
#    Replace <dbname> with "juancarlos"

MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/juancarlos?retryWrites=true&w=majority

# Option B: Local MongoDB (if installed)
# MONGODB_URI=mongodb://localhost:27017/juancarlos

# -------------------------------------------------
# STEP 2: JWT Secret (REQUIRED)
# -------------------------------------------------
# Generate a random string (you can use: https://jwtsecret.com/generate)
# This is used to sign authentication tokens
JWT_SECRET=replace-this-with-a-random-string-at-least-32-characters-long

# -------------------------------------------------
# STEP 3: Server Port (Optional)
# -------------------------------------------------
PORT=5000

# -------------------------------------------------
# STEP 4: Frontend API URL (Usually don't change)
# -------------------------------------------------
VITE_API_URL=http://localhost:5000/api

# -------------------------------------------------
# STEP 5: API Mode (IMPORTANT!)
# -------------------------------------------------
# Set to "true" to use mock data (no database needed)
# Set to "false" to use real MongoDB database
USE_MOCK_API=false
